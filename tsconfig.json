{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    // hap-nodejs ships ambient `const enum`s (SRTPCryptoSuites, H264Profile, …)
    // which are incompatible with verbatimModuleSyntax (TS2748). Our own code
    // keeps using explicit `import type`, so this only relaxes enforcement.
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
